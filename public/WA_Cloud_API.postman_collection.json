{
  "info": {
    "name": "WA Cloud API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "API-Key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "rdSyDHPOIKZErjsoBVRkrH8GU6KW9Pz7",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://pro.wacloud.app/api"
    },
    {
      "key": "instance_id",
      "value": "YOUR_INSTANCE_ID"
    }
  ],
  "item": [
    {
      "name": "Send Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"recipient\": \"88017xxxxxxxx\",\n  \"content\": \"Hello!\",\n  \"instance_id\": \"{{instance_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/send-message"
        }
      }
    },
    {
      "name": "List Devices",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/devices"
        }
      }
    },
    {
      "name": "Device Status",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/device-status/{{instance_id}}"
        }
      }
    },
    {
      "name": "Message Status",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/message-status/MSG_abc123"
        }
      }
    },
    {
      "name": "Check WhatsApp",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/check-whatsapp/{{instance_id}}/88017xxxxxxxx"
        }
      }
    },
    {
      "name": "Send Transactional",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"to\": \"88017xxxxxxxx\",\n  \"device_id\": 1,\n  \"whatsapp\": {\n    \"message\": \"OTP: 1234\"\n  },\n  \"sms\": {\n    \"message\": \"OTP: 1234\"\n  },\n  \"failover_mode\": \"auto\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/send-transactional"
        }
      }
    }
  ]
}
